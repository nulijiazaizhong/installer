name: Mirror to CNB Repo

on:
  push:
    branches:
      - main
      - master

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Mirror to CNB
        run: |
          git config --global user.name "github-bot"
          git config --global user.email "actions@github.com"
          git remote add cnb https://cnb:cyztdMGhtHrJv13b06jn4yKb9IA@cnb.cool/ETS2LA-CN/installer.git
          git push --mirror cnb
